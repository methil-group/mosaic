{
  "name": "mosaic-vscode",
  "displayName": "Mosaic",
  "description": "AI-powered coding assistant with full tool-calling capabilities.",
  "version": "0.0.14",
  "icon": "assets/icon.png",
  "publisher": "methil",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/methil-group/mosaic.git",
    "directory": "vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onView:mosaic.chatView",
    "onCommand:mosaic.focusChat",
    "onCommand:mosaic.resetChat"
  ],
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Education"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mosaic-sidebar",
          "title": "Mosaic",
          "icon": "assets/icon-white.png"
        }
      ]
    },
    "views": {
      "mosaic-sidebar": [
        {
          "type": "webview",
          "id": "mosaic.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "mosaic.focusChat",
        "title": "Focus Mosaic Chat"
      },
      {
        "command": "mosaic.resetChat",
        "title": "Reset Chat",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mosaic.resetChat",
          "group": "navigation",
          "when": "view == mosaic.chatView"
        }
      ]
    },
    "configuration": {
      "title": "Mosaic",
      "properties": {
        "mosaic.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for OpenRouter"
        },
        "mosaic.lmstudioBaseUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "Base URL for LM Studio (e.g. http://localhost:1234/v1)"
        },
        "mosaic.provider": {
          "type": "string",
          "enum": [
            "openrouter",
            "lmstudio"
          ],
          "default": "openrouter",
          "description": "Preferred LLM provider"
        },
        "mosaic.model": {
          "type": "string",
          "default": "deepseek/deepseek-v4-flash",
          "description": "Selected model"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/runTest.js",
    "unit-test": "jest",
    "benchmark": "ts-node repo_test/benchmark.ts",
    "publish-ovsx": "npx ovsx publish"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.39.0",
    "jest": "^29.5.0",
    "mocha": "^11.7.5",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "axios": "^1.4.0",
    "uuid": "^9.0.0"
  }
}
