{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "outDir": "./dist-electron",
        "rootDir": "./electron",
        "sourceMap": true,
        "declaration": false,
        "resolveJsonModule": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "electron/**/*.ts"
    ]
}