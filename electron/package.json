{
  "name": "mosaic",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "nuxt dev --port 3710",
    "build": "nuxt generate",
    "electron:build": "electron-vite build",
    "electron:dev": "electron-vite build && concurrently \"npm run dev\" \"wait-on http://localhost:3710 && cross-env NODE_ENV=development electron . --no-sandbox\"",
    "electron:start": "electron-vite build && electron . --no-sandbox",
    "rebuild": "npx @electron/rebuild -m .",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.13.1",
    "@pinia/nuxt": "^0.11.3",
    "@types/highlight.js": "^9.12.4",
    "@types/markdown-it": "^14.1.2",
    "axios": "^1.13.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.563.0",
    "markdown-it": "^14.1.0",
    "nuxt": "^4.1.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.2.1",
    "electron-vite": "^3.1.0",
    "wait-on": "^9.0.3"
  }
}