{
  "name": "mosaic",
  "type": "module",
  "private": true,
  "main": "out/main/main.js",
  "version": "0.0.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3710",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3710 && cross-env ELECTRON_RENDERER_URL=http://localhost:3710 electron-vite dev\"",
    "electron:build": "npm run generate && electron-vite build",
    "electron:preview": "electron-vite preview",
    "electron:package:mac": "npm run electron:build && electron-builder --mac",
    "electron:package:win": "npm run electron:build && electron-builder --win"
  },
  "build": {
    "appId": "com.mosaic",
    "productName": "Mosaic",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      ".output/public/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@types/markdown-it": "^14.1.2",
    "axios": "^1.13.4",
    "dotenv": "^17.2.3",
    "lucide-vue-next": "^0.563.0",
    "markdown-it": "^14.1.0",
    "nuxt": "^4.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.3"
  }
}
