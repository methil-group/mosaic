{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mosaic",
  "version": "0.1.0",
  "identifier": "com.methil.mosaic",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3710",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "Mosaic",
        "width": 1080,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}